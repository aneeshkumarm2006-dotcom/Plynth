{
  "name": "plynth-monorepo",
  "version": "0.0.1",
  "description": "Plynth - B2B Marketplace for Canadian Mortgage Brokers & Private Lenders",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "preview": "pnpm -r preview",
    "lint": "pnpm -r lint",
    "type-check": "pnpm -r type-check",
    "test": "pnpm -r test",
    "db:push": "cd supabase && supabase push",
    "db:pull": "cd supabase && supabase pull",
    "db:reset": "cd supabase && supabase db reset"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3"
  }
}
