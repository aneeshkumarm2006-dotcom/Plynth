{
  "name": "plynth-monorepo",
  "version": "0.0.1",
  "description": "Plynth - B2B Marketplace for Canadian Mortgage Brokers & Private Lenders",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "preview": "pnpm -r preview",
    "lint": "pnpm -r lint",
    "type-check": "pnpm -r type-check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:migrate": "node scripts/migrate.mjs",
    "db:seed": "node scripts/seed.mjs",
    "db:push": "cd supabase && supabase push",
    "db:pull": "cd supabase && supabase pull",
    "db:reset": "cd supabase && supabase db reset"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@vitest/coverage-v8": "^2.1.8",
    "pg": "^8.11.3",
    "typescript": "^5.3.3",
    "vitest": "^2.1.8"
  }
}
