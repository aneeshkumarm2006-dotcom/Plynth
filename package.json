{
  "name": "plynth-monorepo",
  "version": "0.0.1",
  "description": "Plynth - B2B Marketplace for Canadian Mortgage Brokers & Private Lenders",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "preview": "pnpm -r preview",
    "lint": "pnpm -r lint",
    "type-check": "pnpm -r type-check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:migrate": "node scripts/migrate.mjs",
    "db:seed": "node scripts/seed.mjs",
    "db:push": "cd supabase && supabase push",
    "db:pull": "cd supabase && supabase pull",
    "db:reset": "cd supabase && supabase db reset"
  },
  "dependencies": {
    "node-html-parser": "^6.1.13",
    "sanitize-html": "^2.13.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/sanitize-html": "^2.13.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitest/coverage-v8": "^3.2.6",
    "eslint": "^8.57.1",
    "pg": "^8.21.0",
    "typescript": "^5.3.3",
    "vitest": "^3.2.6"
  }
}
