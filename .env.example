# ============================================================
# Plynth — SERVER-ONLY environment (Vercel Serverless Functions)
# ============================================================
# These are consumed by the functions in api/ and are NEVER bundled into
# any browser app (none are VITE_-prefixed). Set the real values in
# Vercel → Project → Settings → Environment Variables (Production).
#
# The per-app browser vars (VITE_SUPABASE_URL etc.) live in each
# apps/<app>/.env.example — this file is only the server side.
# ------------------------------------------------------------

# ---- Supabase (shared by the blog + email functions) ----
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Anon (public) key — used by the INTERNET-FACING blog functions
# (api/blog/*, api/sitemap.ts) which read only published posts via the
# security-definer RPCs. Non-secret, but kept server-side here.
SUPABASE_ANON_KEY=your-anon-key
# Service-role key — BYPASSES RLS. Used ONLY by the cookie-guarded
# /api/seo/* dashboard endpoints. Keep secret; never expose to a browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- SEO publishing dashboard (/seoteam) ----
# Shared password the SEO team types to log in (constant-time compared).
# Use a long, random value.
SEO_DASHBOARD_PASSWORD=change-me-to-a-long-random-string
# HMAC key used to sign the /seoteam session cookie. Use a long random
# value; rotating it invalidates all existing dashboard sessions.
SESSION_SECRET=change-me-to-a-long-random-string
# Optional — dashboard session lifetime in days (default 7).
SEO_SESSION_TTL_DAYS=7
# Optional — Supabase Storage bucket for blog images (default blog-media).
BLOG_STORAGE_BUCKET=blog-media

# ---- Public site ----
# Canonical origin used for blog canonical/OG URLs and the sitemap.
SITE_URL=https://plynth.com

# ---- Email notifications (existing — see api/notify-email.ts) ----
RESEND_API_KEY=re_your_key
EMAIL_FROM=Plynth <notifications@plynth.com>
EMAIL_WEBHOOK_SECRET=shared-secret-matching-admin_set_email_config
BROKER_APP_URL=https://app.plynth.com
LENDER_APP_URL=https://lender.plynth.com
